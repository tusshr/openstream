{
  "name": "openstream",
  "description": "OpenStream is an open-source LMS platform for building secure, scalable digital learning experiences.",
  "version": "1.0.0",
  "type": "module",
  "author": {
    "name": "Tushar",
    "url": "https://github.com/tusshr"
  },
  "engines": {
    "bun": "^1.3"
  },
  "scripts": {
    "dev": "SERVICE_NAME=openstream-api bun run --watch src/index.ts | bunx pino-pretty --colorize --translateTime 'SYS:HH:MM:ss.l'",
    "dev:worker": "SERVICE_NAME=openstream-worker WORKER_ID=1 PORT=8081 bun run --watch src/worker.ts | bunx pino-pretty --colorize --translateTime 'SYS:HH:MM:ss.l'",
    "start": "SERVICE_NAME=openstream-api bun run src/index.ts",
    "start:worker": "SERVICE_NAME=openstream-worker WORKER_ID=1 bun run src/worker.ts",
    "prepare": "husky",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun src/scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint:fmt": "eslint --fix && prettier --write ."
  },
  "dependencies": {
    "@casl/ability": "^7.0.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@sinclair/typebox": "^0.34.48",
    "bullmq": "^5.76.8",
    "drizzle-orm": "^0.45.1",
    "drizzle-seed": "^0.3.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.25",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/nodemailer": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "bun-types": "^1.3.9",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pg": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": "prettier --write"
  },
  "overrides": {
    "@sinclair/typebox": "0.34.48"
  },
  "module": "src/index.js"
}

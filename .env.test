# Test environment defaults. NOT SECRETS — these are placeholders so env
# validation passes during `bun test`. Tests that need a real Postgres / Redis
# / S3 connection override these via the CI workflow env block (or via a
# local `.env.test.local`, which is gitignored).

DATABASE_URL=postgres://test:test@127.0.0.1:5432/openstream_test
REDIS_URL=redis://127.0.0.1:6379

ALLOWED_ORIGIN=http://localhost:3000

S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_BUCKET=openstream-test
S3_REGION=us-east-1
